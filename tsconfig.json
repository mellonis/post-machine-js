{
  "extends": "@tsconfig/recommended",
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "declaration": true,
    "strict": true,
    "moduleResolution": "node",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "types": ["jest", "node"]
  },
  "exclude": [
    "packages/*/dist/**/*"
  ]
}
